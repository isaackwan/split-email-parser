# ============================================================
#  icbc-email-parser — environment configuration template
#  Copy this file to .env and fill in the real values.
#  .env is git-ignored; .env.example is checked in.
# ============================================================

# ----------------------------------------------------------
# Spliit
# ----------------------------------------------------------

# The group ID from the Spliit group URL
#   e.g. for https://spliit.app/groups/iFGaF-1v8LxH2Vvp-DWpi/expenses
#   the ID is: iFGaF-1v8LxH2Vvp-DWpi
SPLIIT_GROUP_ID=

# Your Spliit participant ID (the person who paid — i.e. you)
# Find it by opening the group in DevTools → Network → any expense request
# and looking at the "paidBy" field.
SPLIIT_PAID_BY_ID=

# Comma-separated list of ALL participant IDs to split the expense with.
# Include your own ID as well.
# Example: abc123,def456,ghi789
SPLIIT_PARTICIPANT_IDS=

# ----------------------------------------------------------
# Telegram
# ----------------------------------------------------------

# Bot token from @BotFather  (format: 123456789:AABBCCDDEEFFaabbccddeeff)
TELEGRAM_BOT_TOKEN=

# Chat ID or user ID to send notifications to.
# Get it by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------

# Absolute path to the NDJSON fallback log file.
# The file is created automatically if it does not exist.
# Recommended: somewhere outside the web root on cPanel.
# Example: /home/yourusername/logs/icbc-parser.log
LOG_FILE=
